# Discord Bot Configuration
DISCORD_BOT_TOKEN=your_bot_token_here
GUILD_ID=your_guild_id_here

# Server Status Monitoring (optional)
SOURCE_CHANNEL_ID=channel_id_to_monitor

# HTTP Server
PORT=3000

# Timezone for date parsing (default: UTC)
TZ=UTC

# GitHub PAT for community marker submissions (optional)
# Needs 'public_repo' scope to create issues on Pix-Elated/ravenhud
GITHUB_PAT=
