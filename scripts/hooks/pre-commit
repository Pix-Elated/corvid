#!/bin/bash
# Pre-commit hook: Validates code quality before committing

set -e

echo "Running pre-commit checks..."

# Get list of staged files
STAGED_TS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx)$' || true)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM || true)

if [ -z "$STAGED_FILES" ]; then
    echo "No staged files to check."
    exit 0
fi

# 1. ESLint check on staged TypeScript files
if [ -n "$STAGED_TS_FILES" ]; then
    echo "Running ESLint on staged TypeScript files..."
    npx eslint $STAGED_TS_FILES --max-warnings 0
    if [ $? -ne 0 ]; then
        echo "ESLint check failed. Please fix the errors above."
        exit 1
    fi
    echo "ESLint check passed."
fi

# 2. TypeScript type check
if [ -n "$STAGED_TS_FILES" ]; then
    echo "Running TypeScript type check..."
    npx tsc --noEmit --skipLibCheck
    if [ $? -ne 0 ]; then
        echo "TypeScript type check failed. Please fix the errors above."
        exit 1
    fi
    echo "TypeScript type check passed."
fi

# 3. Prettier format check on staged files
echo "Checking code formatting with Prettier..."
npx prettier --check $STAGED_FILES 2>/dev/null || {
    echo "Prettier check failed. Run 'npm run format' to fix formatting."
    exit 1
}
echo "Prettier check passed."

echo "All pre-commit checks passed!"
exit 0
