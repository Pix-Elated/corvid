{
  "$schema": "https://json-schema.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run typecheck)",
      "Bash(npm run lint*)",
      "Bash(npm run format*)",
      "Bash(npm run build)",
      "Bash(npm run dev*)",
      "Bash(npm run setup:hooks)",
      "Bash(git fetch *)",
      "Bash(git branch *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git pull *)",
      "Bash(git push *)",
      "Bash(gh pr *)",
      "Bash(gh run *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",
      "Bash(git stash *)",
      "Bash(git rebase -i *)"
    ]
  }
}
